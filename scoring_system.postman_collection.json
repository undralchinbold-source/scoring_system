                  "pm.test('Зөв харилцагч ирсэн', function() {",
                  "  pm.expect(pm.response.json().id).to.equal(pm.collectionVariables.get('client_id'));",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Update Client — Харилцагч засах",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/api/clients/{{client_id}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Дорж Гантулга (шинэчлэгдсэн)\",\n  \"income\": 6000000,\n  \"phone\": \"88334455\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Юу хийдэг: Харилцагчийн мэдээллийг өөрчилнэ.\n\nЗасаж болох талбарууд:\n- fullname : нэр\n- income   : орлого\n- phone    : утас\n\nAnхаарал: national_id засаж болохгүй.\n\nЯмар хариу ирэх:\n- 200 OK     → шинэчлэгдсэн мэдээлэл буцаана\n- 404 Not Found → харилцагч олдсонгүй"
          },
          "event": [
            {
              "listen": "test",
