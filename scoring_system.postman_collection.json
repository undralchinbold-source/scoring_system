                ]
              }
            }
          ]
        },

        {
          "name": "Create Client — Харилцагч үүсгэх",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/clients/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"national_id\": \"МН87654321\",\n  \"fullname\": \"Дорж Гантулга\",\n  \"income\": 4500000,\n  \"phone\": \"99112233\",\n  \"created_by\": \"{{user_id}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Юу хийдэг: Шинэ харилцагч бүртгэнэ.\n\nЗаавал явуулах талбарууд:\n- national_id : регистрийн дугаар (давхардаж болохгүй)\n- fullname    : харилцагчийн бүтэн нэр\n\nЗаавал биш талбарууд:\n- income     : сарын орлого (төгрөгөөр)\n- phone      : утасны дугаар\n- created_by : үүсгэсэн ажилтны user_id (UUID)\n\nЯмар хариу ирэх:\n- 201 Created   → харилцагч амжилттай үүслээ\n- 400 Bad Request  → national_id эсвэл fullname дутуу\n- 409 Conflict   → national_id аль хэдийн бүртгэлтэй"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Харилцагч амжилттай үүслээ (201)', function() {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('client_id хадгалах', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json).to.have.property('id');",
                  "  pm.collectionVariables.set('client_id', json.id);",
                  "  console.log('client_id хадгалагдлаа:', json.id);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Get Client — Нэг харилцагч харах",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/clients/{{client_id}}",
            "description": "Юу хийдэг: ID-аар тодорхой харилцагчийн дэлгэрэнгүй мэдээлэл авна.\n\nЯмар хариу ирэх:\n- 200 OK     → харилцагчийн мэдээлэл\n- 404 Not Found → тийм ID-тай харилцагч байхгүй"
          },
          "event": [
            {
              "listen": "test",
