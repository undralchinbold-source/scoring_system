            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"REVIEW\",\n  \"entity_type\": \"loan_application\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Юу хийдэг: Аудит бүртгэлийн мэдээллийг өөрчилнэ.\n\nЗасаж болох талбарууд:\n- action      : шинэ үйлдлийн нэр\n- entity_type : шинэ обьектын төрөл\n- entity_id   : шинэ обьектын ID\n\nЯмар хариу ирэх:\n- 200 OK     → шинэчлэгдсэн бүртгэл\n- 404 Not Found → бүртгэл байхгүй"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Засвар амжилттай (200)', function() { pm.response.to.have.status(200); });",
                  "pm.test('Үйлдэл шинэчлэгдсэн', function() {",
                  "  pm.expect(pm.response.json().action).to.equal('REVIEW');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Delete Audit Log — Бүртгэл устгах",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/audit-logs/{{log_id}}",
            "description": "Юу хийдэг: Аудит бүртгэлийг устгана.\n\nЯмар хариу ирэх:\n- 200 OK     → { 'message': 'Audit log deleted' }\n- 404 Not Found → бүртгэл байхгүй"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Устгалт амжилттай (200)', function() { pm.response.to.have.status(200); });",
                  "pm.test('Амжилтын мессеж', function() {",
                  "  pm.expect(pm.response.json().message).to.include('deleted');",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "[Алдаа] Get — Байхгүй ID (404)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/audit-logs/00000000-0000-0000-0000-000000000000",
            "description": "Юу хийдэг: Байхгүй UUID-аар хайлт хийнэ.\n\nЯмар хариу ирэх:\n- 404 Not Found → тийм бүртгэл байхгүй\n\nЭнэ алдааны хариу нь HTML формат байна (Flask-ийн дефолт 404)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Байхгүй ID 404 өгнө', function() {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }

  ]
