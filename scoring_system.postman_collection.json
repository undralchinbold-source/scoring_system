                  "  pm.expect(pm.response.json().income).to.equal(6000000);",
                  "});"
                ]
              }
            }
          ]
        },

        {
          "name": "Delete Client — Харилцагч устгах",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/clients/{{client_id}}",
            "description": "Юу хийдэг: Харилцагчийг устгана.\n\nАнхаарал: Харилцагчид зээлийн өргөдөл байвал устгахыг зөвшөөрөхгүй.\nЭхлээд зээлийн өргөдлийг устга, дараа нь харилцагчийг устга.\n\nЯмар хариу ирэх:\n- 200 OK    → { 'message': 'Client deleted' }\n- 404 Not Found → харилцагч байхгүй\n- 409 Conflict  → харилцагчид идэвхтэй зээл бий, устгаж болохгүй"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Устгалт амжилттай эсвэл 409', function() {",
                  "  pm.expect([200, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 409) {",
                  "  console.log('Харилцагчид зээл бий — эхлээд зээлийг устгана уу');",
                  "}"
                ]
              }
            }
          ]
        },

        {
          "name": "[Алдаа] Delete Client — Зээлтэй байхад устгах (409)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/clients/{{client_id}}",
            "description": "Юу хийдэг: Зээлийн өргөдөлтэй харилцагчийг устгахыг оролдно.\n\nЯмар хариу ирэх:\n- 409 Conflict → { 'error': 'Cannot delete client with existing loan applications' }\n\nЭнэ request ажиллахын тулд эхлээд Loan Application үүсгэсэн байх хэрэгтэй."
          },
          "event": [
            {
              "listen": "test",
