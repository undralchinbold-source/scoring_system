{
  "info": {
    "name": "Scoring System API",
    "_postman_id": "scoring-system-v2",
    "description": "Loan Scoring System — Flask REST API\n\nBase URL variable: `{{base_url}}` (default: http://127.0.0.1:5001)\n\nAfter calling **Login**, the `token` variable is set automatically via the test script. All subsequent requests use `Bearer {{token}}`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:5001", "type": "string" },
    { "key": "token",    "value": "",                       "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.access_token) {",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    console.log('Token saved.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/auth/login", "host": ["{{base_url}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\",\n  \"fullname\": \"New User\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/users", "host": ["{{base_url}}"], "path": ["api", "users"] },
            "description": "Required: email, password, role (admin | super_user), fullname\nAccess: super_user only"
          }
        },
        {
          "name": "Get User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id}}"],
              "variable": [{ "key": "user_id", "value": "00000000-0000-0000-0000-000000000000" }]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Updated Name\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id}}"],
              "variable": [{ "key": "user_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Optional fields: fullname, role (admin | super_user)\nAccess: super_user only"
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{user_id}}"],
              "variable": [{ "key": "user_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Access: super_user only"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/clients", "host": ["{{base_url}}"], "path": ["api", "clients"] }
          }
        },
        {
          "name": "Create Client",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"national_id\": \"ББ12345678\",\n  \"fullname\": \"Батбаяр Дорж\",\n  \"income\": 2500000,\n  \"phone\": \"+97699001122\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/clients", "host": ["{{base_url}}"], "path": ["api", "clients"] },
            "description": "Required: national_id, fullname\nOptional: income, phone\nAccess: super_user only"
          }
        },
        {
          "name": "Get Client",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/clients/{{client_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clients", "{{client_id}}"],
              "variable": [{ "key": "client_id", "value": "00000000-0000-0000-0000-000000000000" }]
            }
          }
        },
        {
          "name": "Update Client",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullname\": \"Батбаяр Дорж\",\n  \"income\": 3000000,\n  \"phone\": \"+97699009900\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/clients/{{client_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clients", "{{client_id}}"],
              "variable": [{ "key": "client_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Optional fields: national_id, fullname, income, phone\nAccess: super_user only"
          }
        },
        {
          "name": "Delete Client",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/clients/{{client_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "clients", "{{client_id}}"],
              "variable": [{ "key": "client_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "409 Conflict if client has existing loan applications.\nAccess: super_user only"
          }
        }
      ]
    },
    {
      "name": "Loan Applications",
      "item": [
        {
          "name": "List Loan Applications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/loan-applications", "host": ["{{base_url}}"], "path": ["api", "loan-applications"] }
          }
        },
        {
          "name": "Create Loan Application",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"client_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"requested_amount\": 10000000\n}"
            },
            "url": { "raw": "{{base_url}}/api/loan-applications", "host": ["{{base_url}}"], "path": ["api", "loan-applications"] },
            "description": "Required: client_id (UUID), requested_amount\nDefault status: pending\nAccess: super_user only"
          }
        },
        {
          "name": "Get Loan Application",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/loan-applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "loan-applications", "{{application_id}}"],
              "variable": [{ "key": "application_id", "value": "00000000-0000-0000-0000-000000000000" }]
            }
          }
        },
        {
          "name": "Update Loan Application",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"requested_amount\": 12000000\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/loan-applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "loan-applications", "{{application_id}}"],
              "variable": [{ "key": "application_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Optional fields: status (pending | approved | rejected | cancelled), requested_amount\nAccess: super_user only"
          }
        },
        {
          "name": "Delete Loan Application",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/loan-applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "loan-applications", "{{application_id}}"],
              "variable": [{ "key": "application_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Cascades to ScoreHistory and Notifications.\nAccess: super_user only"
          }
        }
      ]
    },
    {
      "name": "Predict (ML Score)",
      "item": [
        {
          "name": "Predict Credit Score",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"application_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"monthly_income\": 2500000,\n  \"employment_years\": 3.5,\n  \"requested_amount\": 10000000,\n  \"employment_type\": \"Employed\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/predict", "host": ["{{base_url}}"], "path": ["api", "predict"] },
            "description": "Runs ML model and saves a ScoreHistory record automatically.\n\nRequired fields:\n- application_id (UUID) — must exist in DB\n- monthly_income (number > 0)\n- employment_years (number)\n- requested_amount (number > 0)\n- employment_type (string — must match model label encoder classes, e.g. \"Employed\", \"Self-Employed\", \"Unemployed\")\n\nResponse includes: credit_score (200–950), approval_probability, decision, model_name, model_version\n\nAccess: admin or super_user"
          }
        }
      ]
    },
    {
      "name": "Score History",
      "item": [
        {
          "name": "List Score History",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/score-history", "host": ["{{base_url}}"], "path": ["api", "score-history"] }
          }
        },
        {
          "name": "Create Score History",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"application_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"model_version\": \"v1.0\",\n  \"score\": 720.0,\n  \"decision\": \"approved\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/score-history", "host": ["{{base_url}}"], "path": ["api", "score-history"] },
            "description": "Required: application_id, model_version, score, decision\nNote: normally auto-created by /api/predict. Manual creation is for super_user only."
          }
        },
        {
          "name": "Get Score History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/score-history/{{score_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "score-history", "{{score_id}}"],
              "variable": [{ "key": "score_id", "value": "00000000-0000-0000-0000-000000000000" }]
            }
          }
        },
        {
          "name": "Update Score History",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"score\": 750.0,\n  \"decision\": \"approved\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/score-history/{{score_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "score-history", "{{score_id}}"],
              "variable": [{ "key": "score_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Access: super_user only"
          }
        },
        {
          "name": "Delete Score History",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/score-history/{{score_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "score-history", "{{score_id}}"],
              "variable": [{ "key": "score_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Access: super_user only"
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/notifications", "host": ["{{base_url}}"], "path": ["api", "notifications"] }
          }
        },
        {
          "name": "Create Notification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"application_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"channel\": \"email\",\n  \"recipient\": \"client@example.com\",\n  \"subject\": \"Зээлийн өргөдлийн шийдвэр\",\n  \"message_body\": \"Таны зээлийн өргөдөл батлагдлаа.\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/notifications", "host": ["{{base_url}}"], "path": ["api", "notifications"] },
            "description": "Required: channel, recipient, message_body\nOptional: application_id, subject\nDefault status: pending\nAccess: super_user only"
          }
        },
        {
          "name": "Get Notification",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/notifications/{{notification_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "{{notification_id}}"],
              "variable": [{ "key": "notification_id", "value": "00000000-0000-0000-0000-000000000000" }]
            }
          }
        },
        {
          "name": "Update Notification",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"sent\",\n  \"message_body\": \"Updated message.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/{{notification_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "{{notification_id}}"],
              "variable": [{ "key": "notification_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Access: super_user only"
          }
        },
        {
          "name": "Delete Notification",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/notifications/{{notification_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "{{notification_id}}"],
              "variable": [{ "key": "notification_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Access: super_user only"
          }
        }
      ]
    },
    {
      "name": "Audit Logs",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/audit-logs", "host": ["{{base_url}}"], "path": ["api", "audit-logs"] }
          }
        },
        {
          "name": "Create Audit Log",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"CREATE\",\n  \"entity_type\": \"LoanApplication\",\n  \"entity_id\": \"00000000-0000-0000-0000-000000000000\",\n  \"user_id\": \"00000000-0000-0000-0000-000000000000\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/audit-logs", "host": ["{{base_url}}"], "path": ["api", "audit-logs"] },
            "description": "Required: action, entity_type\nOptional: entity_id (UUID), user_id (UUID)\nAccess: super_user only"
          }
        },
        {
          "name": "Get Audit Log",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/audit-logs/{{log_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "audit-logs", "{{log_id}}"],
              "variable": [{ "key": "log_id", "value": "00000000-0000-0000-0000-000000000000" }]
            }
          }
        },
        {
          "name": "Update Audit Log",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"UPDATE\",\n  \"entity_type\": \"Client\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/audit-logs/{{log_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "audit-logs", "{{log_id}}"],
              "variable": [{ "key": "log_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Access: super_user only"
          }
        },
        {
          "name": "Delete Audit Log",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/audit-logs/{{log_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "audit-logs", "{{log_id}}"],
              "variable": [{ "key": "log_id", "value": "00000000-0000-0000-0000-000000000000" }]
            },
            "description": "Access: super_user only"
          }
        }
      ]
    }
  ]
}
